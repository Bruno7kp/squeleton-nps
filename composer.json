{
  "name": "bruno-varela/squeleton-nps",
  "description": "Sistema de pesquisas NPS com Slim, SQLite, HTMX e VanJS",
  "type": "project",
  "require": {
    "php": "^8.2",
    "slim/slim": "^4.14",
    "slim/psr7": "^1.7",
    "vlucas/phpdotenv": "^5.6"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "scripts": {
    "post-install-cmd": [
      "@php -r \"if (!file_exists('.env') && file_exists('.env.example')) copy('.env.example', '.env');\""
    ],
    "post-update-cmd": [
      "@composer dump-autoload"
    ]
  }
}
